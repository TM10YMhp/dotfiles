[alias]
	loa = log --oneline --all
	loaf = log --oneline --all -15
	sts = status -sb
	st = status
	co = checkout
	br = branch
	ci = commit
	loag = log --oneline --all --graph
	loafg = log --oneline --all --graph -15
  last = log -1 HEAD --stat
	empty = commit --allow-empty
